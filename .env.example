# =============================================================================
# Teastream Backend — Environment Variables
# Copy to .env for local development (loaded when NODE_ENV=development)
# =============================================================================

# --- Application ---
NODE_ENV=development
APPLICATION_PORT=3000
ALLOWED_ORIGIN=http://localhost:3001
# Public URL of the web frontend — used to build clickable links in transactional
# emails (verify, password reset, etc.). Defaults to ALLOWED_ORIGIN if unset.
FRONTEND_URL=http://localhost:3001
GRAPHQL_PREFIX=/graphql

# --- Session & Cookies ---
SESSION_SECRET=change-me-session-secret-min-32-chars
SESSION_NAME=teastream.sid
SESSION_MAX_AGE=7d
SESSION_HTTP_ONLY=true
SESSION_SECURE=false
SESSION_FOLDER=sess:
COOKIE_SECRET=change-me-cookie-secret

# --- Database (PostgreSQL) ---
# Prisma accepts DATABASE_URL or POSTGRES_URI
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/teastream?schema=public
POSTGRES_URI=postgresql://postgres:postgres@localhost:5433/teastream?schema=public
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# --- Redis (sessions + optional cache) ---
REDIS_URI=redis://:password@localhost:6379
REDIS_PASSWORD=password
# REDIS_ACL=true  # optional: enable ACL URL format in redis-options.util

# --- Mail (SMTP) ---
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_LOGIN=noreply@example.com
MAIL_PASSWORD=

# --- LiveKit (streaming ingress) ---
LIVEKIT_API_URL=https://your-livekit-host
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# --- Stripe (sponsorship payments) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=
