# =============================================================================
# Teastream Web — Environment Variables (Vite)
# =============================================================================
# Backend GraphQL endpoint. The dev server proxies /graphql to this origin
# (see vite.config.ts), so in dev you can leave VITE_GRAPHQL_URL=/graphql.
# In production, point VITE_GRAPHQL_URL at the public backend URL.

VITE_API_URL=http://localhost:3000
VITE_GRAPHQL_URL=/graphql
VITE_GRAPHQL_WS_URL=ws://localhost:3001/graphql
VITE_APP_NAME=Teastream
