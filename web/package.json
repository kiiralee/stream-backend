    "@mantine/form": "^7.17.5",
    "@mantine/hooks": "^7.17.5",
    "@mantine/modals": "^7.17.5",
    "@mantine/notifications": "^7.17.5",
    "@tabler/icons-react": "^3.34.0",
    "@tanstack/react-query": "^5.62.0",
    "@tanstack/react-query-devtools": "^5.62.0",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.13",
    "graphql": "^16.9.0",
